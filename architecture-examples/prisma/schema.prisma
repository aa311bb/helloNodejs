// ============================================
// Prisma Schema - 数据库模型定义
// ============================================
//
// Prisma 是什么？
// Prisma 是一个现代的 ORM（对象关系映射）工具
// 你用这个 schema 文件定义数据模型，Prisma 会自动帮你：
// 1. 生成数据库表（migrate）
// 2. 生成类型安全的查询代码
//
// 对比 Knex：
// - Knex 是查询构建器，你需要自己写 SQL 逻辑
// - Prisma 是 ORM，你只需要定义模型，查询更简洁
//
// 对比 express-mysql.js 中用的 Knex：
// - Knex: db('users').select('*').where({ id: 1 })
// - Prisma: prisma.user.findUnique({ where: { id: 1 } })
// Prisma 更直观，不需要写表名字符串

// datasource - 数据库连接（Prisma 7 中 url 在 prisma.config.ts 里配置）
datasource db {
  provider = "mysql"
}

// generator - 代码生成器配置
generator client {
  provider = "prisma-client-js" // 生成 JavaScript 客户端
}

// ============================================
// 数据模型定义
// 每个 model 会对应数据库中的一张表
// ============================================

// 用户表
model User {
  // @id 表示主键，@default(autoincrement()) 表示自增
  id        Int      @id @default(autoincrement()) @map("id") @db.Int
  // @db.VarChar(50) 对应 MySQL 的 VARCHAR(50)
  // @map("name") 映射到数据库字段名（驼峰 → 下划线）
  name      String   @db.VarChar(50)
  // @unique 表示唯一约束
  email     String   @unique @db.VarChar(100)
  // ? 表示可选字段（数据库中可以为 NULL）
  age       Int?     @db.Int
  gender    String   @default("other") @db.VarChar(10)
  // @default(1) 默认值为 1
  status    Int      @default(1) @db.UnsignedTinyInt
  // @updatedAt 自动更新为当前时间（Prisma 内置功能）
  // 不需要像 Knex 那样手动传 db.fn.now()
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  // 关系定义：一个用户可以有多篇文章
  // articles Article[] 表示 User 模型有一个 articles 属性
  // 它关联到 Article 模型的 author 字段
  articles Article[]

  // @@map("users") 表示这个模型对应数据库的 users 表
  // Prisma 模型名是 User（单数），表名是 users（复数）
  @@map("users")
}

// 文章表
model Article {
  id        Int      @id @default(autoincrement()) @db.Int
  title     String   @db.VarChar(200)
  content   String?  @db.Text
  // 关系字段：author 关联到 User 模型
  // @relation 引用 User 的 id，外键存在 author_id 列
  // onDelete Cascade 表示删除用户时级联删除文章
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  Int      @map("author_id") @db.Int
  views     Int      @default(0) @db.UnsignedInt
  price     Decimal  @default(0) @db.Decimal(10, 2)
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  // 多对多关系的中间表
  tags ArticleTag[]

  @@map("articles")
}

// 标签表
model Tag {
  id        Int      @id @default(autoincrement()) @db.Int
  name      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  articles ArticleTag[]

  @@map("tags")
}

// 文章-标签关联表（多对多中间表）
model ArticleTag {
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId Int      @map("article_id") @db.Int
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     Int      @map("tag_id") @db.Int
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  // 复合主键（同一个文章不能重复打同一个标签）
  @@id([articleId, tagId])
  @@map("article_tags")
}
